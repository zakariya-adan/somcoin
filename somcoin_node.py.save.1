def request_peers():
    global p2p_peers

    for peer in list(p2p_peers):
        try:
            host, port = peer.split(":")
            port = int(port)

            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.settimeout(3)

            s.connect((host, port))

            s.sendall((json.dumps({
                "type": "get_peers"
            }) + "\n").encode())

            data = s.recv(8192)

            if not data:
                continue

            try:
                resp = json.loads(data.decode())

                if resp.get("type") == "peers":

                    new_peers = resp.get("data", [])
                    seen_ips = set()

                    for p in new_peers:
                        try:
                            ip, prt = p.split(":")
                            prt = int(prt)

                            # ✅ only allowed port
                            if prt not in ALLOWED_PORTS:
                                continue

                            # 🚫 skip duplicates
                            if ip in seen_ips or ip in peer_ips:
                                continue

                            seen_ips.add(ip)

                            peer_addr = f"{ip}:{prt}"

                            if len(p2p_peers) < MAX_PEERS:
                                p2p_peers.add(peer_addr)
                                peer_ips.add(ip)

                                print("🌐 Peer discovered:", peer_addr)

                        except:
                            continue

            except:
                pass

            s.close()

        except:
            continue

# ==================================================
# SAFE MULTI MESSAGE HANDLER
# ==================================================
def safe_handle(data, conn):
    messages = data.split("\n")

    for msg in messages:
        if msg.strip():
            handle_msg(msg, conn)

def send_msg(conn, data):
    try:
        if not isinstance(data, dict):
            return
        msg = json.dumps(data) + "\n"
        conn.sendall(msg.encode())
    except Exception as e:
        pass

# ==================================================
# HANDLE P2P MESSAGE (ULTRA PRO + SAFE + P2P SYNC)
# ==================================================
def handle_msg(msg, conn):

    global blockchain, p2p_peers, pending_transactions

    try:
        # =========================================
        # 🔒 HARD LIMIT
        # =========================================
        if isinstance(msg, str) and len(msg) > 100000:
            return

        # =========================================
        # 🔥 SAFE PARSE
        # =========================================
        try:
            data = json.loads(msg) if isinstance(msg, str) else msg
        except:
            return

        if not isinstance(data, dict):
            return

        msg_type = data.get("type")

        # =========================================
        # 📢 INV
        # =========================================
        if msg_type == "inv":

            for item in data.get("data", []):
                typ = item.get("type")
                item_id = item.get("id")

                if not typ or not item_id:
                    continue

                if typ == "tx":
                    if any(tx_hash(tx) == item_id for tx in pending_transactions):
                        continue

                elif typ == "block":
                    if any(b["hash"] == item_id for b in blockchain):
                        continue

                send_msg(conn, {
                    "type": "getdata",
                    "data": [item]
                })

        # =========================================
        # 📥 GETDATA
        # =========================================
        elif msg_type == "getdata":

            for item in data.get("data", []):
                typ = item.get("type")
                item_id = item.get("id")

                if typ == "tx":
                    for tx in pending_transactions:
                        if tx_hash(tx) == item_id:
                            send_msg(conn, {"type": "tx", "data": tx})

                elif typ == "block":
                    for b in blockchain:
                        if b["hash"] == item_id:
                            send_msg(conn, {"type": "block", "data": b})

        # =========================================
        # 💸 TX
        # =========================================
        elif msg_type == "tx":

            tx = data.get("data")
            if not isinstance(tx, dict):
                return

            with mempool_lock:
                if any(tx_hash(t) == tx_hash(tx) for t in pending_transactions):
                    return

                if not verify_tx(tx):
                    return

                pending_transactions.append(tx)

            print("💸 TX accepted")

            # INV
            p2p_broadcast({
                "type": "inv",
                "data": [{"type": "tx", "id": tx_hash(tx)}]
            })

            # 🔥 DIRECT FALLBACK
            p2p_broadcast({
                "type": "tx",
                "data": tx
            })

        # =========================================
        # 📦 BLOCK
        # =========================================
        elif msg_type == "block":

            block = data.get("data")
            if not isinstance(block, dict):
                return

            if any(b["hash"] == block.get("hash") for b in blockchain):
                return

            if blockchain and block.get("previous_hash") != blockchain[-1]["hash"]:
                print("⚠️ Orphan block")
                request_chain()
                return

            try:
                tx_str = json.dumps(block["transactions"], sort_keys=True)
            except:
                return

            calc_hash = calculate_hash(
                block["index"],
                block["previous_hash"],
                block["timestamp"],
                block["nonce"],
                tx_str
            )

            if calc_hash != block.get("hash"):
                return

            if not calc_hash.startswith("0" * block.get("difficulty", 1)):
                return

            used_inputs = set()
            for tx in block.get("transactions", []):
                if not verify_tx(tx, used_inputs):
                    return

            with blockchain_lock:
                blockchain.append(block)
                update_utxo(block)

            save_data()
            print("✅ Block accepted:", block["index"])

            # INV
            p2p_broadcast({
                "type": "inv",
                "data": [{"type": "block", "id": block["hash"]}]
            })

            # 🔥 DIRECT FALLBACK
            p2p_broadcast({
                "type": "block",
                "data": block
            })

        # =========================================
        # 🔄 GET CHAIN
        # =========================================
        elif msg_type == "get_chain":

            send_msg(conn, {
                "type": "chain",
                "data": blockchain
            })

        # =========================================
        # 🔄 CHAIN RESPONSE
        # =========================================
        elif msg_type == "chain":

            new_chain = data.get("data")
            if not isinstance(new_chain, list):
                return

            valid = True

            for i in range(1, len(new_chain)):
                prev = new_chain[i-1]
                curr = new_chain[i]

                if curr.get("previous_hash") != prev.get("hash"):
                    valid = False
                    break

                try:
                    tx_str = json.dumps(curr["transactions"], sort_keys=True)
                except:
                    valid = False
                    break

                calc_hash = calculate_hash(
                    curr["index"],
                    curr["previous_hash"],
                    curr["timestamp"],
                    curr["nonce"],
                    tx_str
                )

                if calc_hash != curr.get("hash"):
                    valid = False
                    break

            if valid and len(new_chain) > len(blockchain):
                print("🔄 Chain replaced")

                with blockchain_lock:
                    blockchain.clear()
                    blockchain.extend(new_chain)

                rebuild_utxo()
                save_data()

        # =========================================
        # 🤝 HELLO
        # =========================================
        elif msg_type == "hello":

            port = data.get("port")
            node_id = data.get("node_id")
            public_key = data.get("public_key")
            signature = data.get("signature")

            if not verify_node(node_id, public_key, signature):
                return

            try:
                port = int(port)
            except:
                return

            if port not in ALLOWED_PORTS:
                return

            ip = conn.getpeername()[0]

            # ❌ SELF BLOCK
            SERVER_IP = "0.0.0.0"

            if ip.startswith("127.") or ip.startswith("0.") or ip in banned_ips:
                return

            # ❌ MULTI CONNECTION LIMIT
            same_ip = [p for p in p2p_peers if p.startswith(ip + ":")]
            if len(same_ip) >= MAX_CONNECTIONS_PER_IP:
                return

            if ip in peer_id_map and peer_id_map[ip] != node_id:
                banned_ips.add(ip)
                return

            peer_id_map[ip] = node_id

            peer = f"{ip}:{port}"

            if ip not in peer_ips and len(p2p_peers) < MAX_PEERS:
                p2p_peers.add(peer)
                peer_ips.add(ip)
                peer_scores[peer] = 0
                mark_peer_alive(peer)

                save_data()

                print("✅ Peer:", peer)

            # reply hello
            send_msg(conn, {
                "type": "hello",
                "node_id": NODE_ID,
                "port": P2P_PORT,
                "public_key": NODE_PUBLIC_KEY,
                "signature": sign_message(NODE_ID)
            })

            # 🔥 AUTO SHARE PEERS
            send_msg(conn, {
                "type": "peers",
                "data": list(p2p_peers)
            })

            # 🔥 REQUEST MORE
            send_msg(conn, {"type": "get_peers"})

        # =========================================
        # 🌐 GET PEERS
        # =========================================
        elif msg_type == "get_peers":

            send_msg(conn, {
                "type": "peers",
                "data": list(p2p_peers)
            })

        # =========================================
        # 🌐 PEERS
        # =========================================
        elif msg_type == "peers":

            for p in data.get("data", []):
                try:
                    ip, port = p.split(":")
                    port = int(port)

                    if (
                        ip.startswith("127.")
                        or ip.startswith("0.")
                        or ip in banned_ips
                        or port not in ALLOWED_PORTS
                        or ip in peer_ips
                    ):
                        continue

                    if len(p2p_peers) < MAX_PEERS:
                        peer = f"{ip}:{port}"
                        p2p_peers.add(peer)
                        peer_ips.add(ip)
                        peer_scores[peer] = 0

                except:
                    continue

        # =========================================
        # ❤️ PING / PONG
        # =========================================
        elif msg_type == "ping":
            send_msg(conn, {"type": "pong"})

        elif msg_type == "pong":
            peer = f"{conn.getpeername()[0]}:{P2P_PORT}"
            mark_peer_alive(peer)

    except Exception as e:
        print("P2P error:", e)


