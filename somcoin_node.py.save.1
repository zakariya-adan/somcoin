# =========================
# 🛡 FORK VALIDATION
# =========================
def is_valid_chain(chain):
    try:
        for i in range(1, len(chain)):
            prev = chain[i - 1]
            curr = chain[i]

            if curr["previous_hash"] != hash_block(prev):
                return False

            if not valid_proof(curr):
                return False

        return True

    except:
        return False


